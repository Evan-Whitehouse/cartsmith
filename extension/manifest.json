{
  "manifest_version": 3,
  "name": "cartsmith",
  "version": "0.1.0",
  "description": "Paste a Riftbound deck list and add the cheapest few-seller TCGplayer cart in one click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "cartsmith"
  },
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "*://*.tcgplayer.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
